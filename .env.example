# Copy to .env and fill in.
# Required for remote=True runs against NDIF.
NDIF_API_KEY=
# Required for the LLM judge in intended-outputs/judge_results.py.
ANTHROPIC_API_KEY=
# Required for downloading tokenizer/config from Hugging Face for gated Llama models.
HF_TOKEN=
# Optional: only needed if you swap in OpenAI as the judge.
OPENAI_API_KEY=
